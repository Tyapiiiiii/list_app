<h1>通知</h1>

<% if @pending_invitations.any? %>
  <table class="notification-table">
    <thead>
      <tr>
        <th>送信者</th>
        <th>テンプレート</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @pending_invitations.each do |relation| %>
        <tr>
          <td><%= relation.template.user.email %></td>
          <td><%= relation.template.title %></td>
          <td>
            <div class="action-cell">
              <%= button_to "承認する", template_relation_path(relation), method: :patch, class: "btn btn-sm" %>
              <%= button_to "辞退する", template_relation_path(relation), method: :delete,
                  data: { turbo_confirm: "本当に辞退しますか？" },
                  class: "btn btn-sm btn-danger" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">通知はありません。</p>
<% end %>
