<h1><%= @template.title %> の持ち物チェック</h1>
<p><%= @template.memo %></p>

<hr>

<div id="items-list">
  <% @template.items.each do |item| %>
    <div id="item_<%= item.id %>" style="margin-bottom: 10px; font-size: 18px;">
      <%= button_to toggle_check_item_path(item), method: :patch, style: "background: none; border: none; cursor: pointer; text-align: left; font-size: 18px;" do %>
        <% if item.is_checked %>
          <span style="color: green; font-weight: bold;">☑️ <s><%= item.name %></s></span>
        <% else %>
          <span>⬛ <%= item.name %></span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<hr>

<h3>🤝 共同編集メンバー</h3>

<% if @template.user == current_user %>
  <%= form_with(url: template_template_relations_path(@template), local: true) do |f| %>
    <div class="field">
      <%= f.label :email, "招待したいユーザーのメールアドレス" %><br>
      <%= f.email_field :email, placeholder: "example@email.com", required: true %>
      <%= f.submit "招待を送る" %>
    </div>
  <% end %>

  <h4>現在のメンバー一覧</h4>
  <ul>
    <li>👑 <%= @template.user.email %> (オーナー)</li>
    <% @template.template_relations.each do |relation| %>
      <% if relation.persisted? %>
        <li>
          <%= relation.user.email %> 
          (<%= relation.status_i18n || relation.status %>)
        </li>
      <% end %>
    <% end %>
  </ul>

<% else %>
  <p>オーナー: <%= @template.user.email %></p>
<% end %>

<hr>

<p>
  <% if @template.user == current_user || @template.shared_users.include?(current_user) %>
    <%= link_to "✏️ このテンプレートを編集する", edit_template_path(@template) %> | 
    <%= link_to "🗑️ テンプレートを削除する", template_path(@template), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, style: "color: red;" %>
  <% end %>
</p>

<p><%= link_to "← 一覧に戻る", root_path %></p>