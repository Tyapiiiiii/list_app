<% pending_invitations = current_user.template_relations.where(status: :pending) %>

<% if pending_invitations.any? %>
  <div style="background-color: #fff3cd; border: 1px solid #ffeeba; padding: 15px; margin-bottom: 20px; border-radius: 5px;">
    <h3 style="margin-top: 0; color: #856404;">📩 共同編集の招待が届いています</h3>
    <ul>
      <% pending_invitations.each do |relation| %>
        <li style="margin-bottom: 10px;">
          <strong><%= relation.template.user.email %></strong> さんから
          「<strong><%= relation.template.title %></strong>」への共同編集の招待
          
          <div style="margin-top: 5px;">
            <%= button_to "承認する", template_relation_path(relation), method: :patch, style: "background-color: #28a745; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer; margin-right: 5px; display: inline-block;" %>
            
            <%= button_to "辞退する", template_relation_path(relation), method: :delete, data: { confirm: "本当に辞退しますか？" }, style: "background-color: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer; display: inline-block;" %>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<h1>持ち物テンプレート一覧（仮トップページ）</h1>

<% if user_signed_in? %>
  <p>ログイン中: <%= current_user.name %>（<%= current_user.email %>）</p>
  <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete } %>
  
  <hr>
  <p><%= link_to "＋ 新しいテンプレートを作る", new_template_path %></p>

  <h3>あなたのテンプレート一覧</h3>
  <% if @templates.any? %>
    <ul>
      <% @templates.each do |template| %>
        <li>
          <strong><%= link_to template.title, template_path(template) %></strong> （持ち物: <%= template.items.count %>個）<br>
          <small><%= template.memo %></small>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>まだテンプレートがありません。</p>
  <% end %>

<% else %>
  <p>ログインしていません</p>
  <%= link_to "ログイン", new_user_session_path %> |
  <%= link_to "アカウント新規作成", new_user_registration_path %> |
  <%= button_to "ゲストログイン（手軽に試す）", guest_login_path, method: :post %>
<% end %>