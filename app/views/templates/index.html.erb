<% if current_user.template_relations.where(status: :pending).exists? %>
  <div class="alert-banner">
    📩 共同編集の招待が届いています ―
    <%= link_to "通知を確認する", notifications_path %>
  </div>
<% end %>

<div class="page-header">
  <div class="page-header-left">
    <h1>持ち物テンプレート一覧</h1>
    <div id="weather-widget" class="weather-widget" style="display:none;"></div>
  </div>
  <%= link_to "＋ 新規作成", new_template_path, class: "btn" %>
</div>

<script>
  const WEATHER_API_KEY = "<%= Rails.application.credentials.dig(:openweathermap, :api_key) %>";
  const WEATHER_MAP = {
    Clear: "晴れ☀️", Clouds: "くもり☁️", Rain: "雨🌧️",
    Drizzle: "小雨🌦️", Thunderstorm: "雷雨⛈️", Snow: "雪❄️",
    Mist: "霧🌫️", Fog: "霧🌫️", Haze: "霞🌫️"
  };

  if (WEATHER_API_KEY && navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(function(pos) {
      const { latitude: lat, longitude: lon } = pos.coords;
      fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lon}&appid=${WEATHER_API_KEY}&units=metric`)
        .then(r => r.json())
        .then(data => {
          const condition = data?.weather?.[0]?.main;
          const label = WEATHER_MAP[condition] || condition;
          const widget = document.getElementById("weather-widget");
          if (label && widget) {
            widget.textContent = `今日の天気：${label}`;
            widget.style.display = "";
          }
        });
    });
  }
</script>

<% if @templates.any? %>
  <div class="template-cards">
    <% @templates.each do |template| %>
      <%= link_to template_path(template), class: "template-card" do %>
        <div class="template-card-header">
          <div class="template-card-icon">
            <i class="<%= template.icon_class.presence || 'fa-solid fa-list' %>"></i>
          </div>
          <div class="template-card-title"><%= template.title %></div>
        </div>
        <div class="template-card-meta">持ち物: <%= template.items.count %>個</div>
        <% if template.memo.present? %>
          <div class="template-card-memo"><%= template.memo %></div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p class="empty-state">まだテンプレートがありません。</p>
<% end %>
